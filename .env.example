# Database (Postgres / Supabase 등)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Auth.js (NextAuth v5)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Google OAuth (사장님 로그인)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Kakao OAuth (사장님 로그인 — 선택적)
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# Solapi 메시징 (선택적 — 미설정 시 알림 발송 자동 skip)
# 필수 3개: SOLAPI_API_KEY, SOLAPI_API_SECRET, DEFAULT_SENDER
# DEFAULT_SENDER는 Solapi에 등록·인증된 발신번호
SOLAPI_API_KEY=""
SOLAPI_API_SECRET=""
DEFAULT_SENDER=""

# 카카오 알림톡 (선택적 — 미설정 시 SMS만)
# KAKAO_PF_ID는 카카오 비즈니스 채널 ID
KAKAO_PF_ID=""
# 템플릿 ID prefix (예: "BOOKING_") — 호출 시 templateId 앞에 자동 부착
KAKAO_TEMPLATE_PREFIX=""

# License
LICENSE_SECRET=""

# App
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
